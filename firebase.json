{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "admin-hosting",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" }
        ]
      }
    ]
  }
}
